{
  "name": "mce",
  "type": "module",
  "version": "0.24.4",
  "description": "A headless infinite canvas editor framework built on WebGL rendering, supports exporting to image, video, and PPT. Only the ESM.",
  "author": "wxm",
  "license": "MIT",
  "homepage": "https://github.com/qq15725/mce",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qq15725/mce.git"
  },
  "bugs": {
    "url": "https://github.com/qq15725/mce/issues"
  },
  "keywords": [
    "vue",
    "webgl",
    "modern",
    "infinite",
    "canvas",
    "editor",
    "mce",
    "typescript"
  ],
  "sideEffects": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./styles": {
      "default": "./dist/index.css"
    },
    "./*.mjs": "./*.js",
    "./*": "./*"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "browser": "./dist/index.js",
  "typings": "dist/index.d.ts",
  "types": "dist/index.d.ts",
  "styles": "dist/index.css",
  "typesVersions": {
    "*": {
      "*": [
        "*",
        "dist/*",
        "dist/*.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:code": "vite build",
    "build:tsc": "NODE_ENV=production vue-tsc --emitDeclarationOnly --project tsconfig.json",
    "build:preset": "jiti ./scripts/preset.ts",
    "build:dts": "jiti ./scripts/dts.ts",
    "build:doc": "typedoc",
    "build": "pnpm build:code && pnpm build:tsc && pnpm build:dts",
    "lint": "eslint src",
    "test": "vitest",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@floating-ui/vue": "^2.0.0",
    "@vueuse/components": "^14.3.0",
    "@vueuse/core": "^14.3.0",
    "diff": "^9.0.0",
    "lodash-es": "^4.18.1",
    "modern-canvas": "^0.23.14",
    "modern-font": "^0.6.1",
    "modern-idoc": "^0.11.9",
    "modern-text": "^2.0.6",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.31"
  },
  "peerDependencies": {
    "echarts": "^5 || ^6",
    "lottie-web": "^5",
    "modern-gif": "^2",
    "typescript": ">=4.7",
    "vue": "^3.5.0",
    "yoga-layout": "^3"
  },
  "peerDependenciesMeta": {
    "echarts": {
      "optional": true
    },
    "lottie-web": {
      "optional": true
    },
    "modern-gif": {
      "optional": true
    },
    "typescript": {
      "optional": true
    },
    "yoga-layout": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@vitejs/plugin-vue": "^6.0.7",
    "jiti": "^2.7.0",
    "sass-embedded": "^1.100.0",
    "typedoc": "^0.28.19"
  }
}
